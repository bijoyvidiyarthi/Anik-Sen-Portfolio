# Anik Sen Portfolio CMS — Root-level Apache configuration
# Upload the entire project folder to public_html/ or www/ on shared hosting.
# This file must be in the same folder as index.php.
# This file handles the 403 Forbidden error on root and maintains security.

# default file set to index.php and stop the directory listing
DirectoryIndex index.php
Options -Indexes -MultiViews +FollowSymLinks

# ── Character encoding ────────────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── Compression (speeds up CSS/JS/HTML delivery) ─────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# ── Browser caching for static assets ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ── Security: block direct access to sensitive files ─────────────────────────
<FilesMatch "\.(env|sqlite|nix|lock|json|md|txt|sql|gitattributes|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<Files "composer.json">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# ── Rewrite rules ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (SSL থাকলে নিচের দুটি লাইনের # মুছে দিন)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block direct access to back-end folders
    RewriteRule ^(classes|config|data|sql|docs|attached_assets)(/|$) - [F,L]

    # 1. redirect root request(/) to index.php  (403 fix)
    RewriteRule ^$ index.php [L]

    # 2. if requested file exist then show it
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Send all request to (eg. /kutta) index.php
    RewriteRule ^ index.php [L]
</IfModule>

# ── Fallback if mod_rewrite is not available ──────────────────────────────────
<IfModule !mod_rewrite.c>
    FallbackResource /index.php
</IfModule>