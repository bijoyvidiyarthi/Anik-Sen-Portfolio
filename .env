# ---------- Application ----------
APP_BASE_URL="http://anik-sen.atwebpages.com/"
APP_DEBUG=true
APP_TIMEZONE="Asia/Dhaka"

# ---------- Database driver: sqlite (default) | mysql ----------

DB_DRIVER="sqlite"

# MySQL / MariaDB (used when DB_DRIVER=mysql)
DB_HOST="fdb1034.awardspace.net"
DB_PORT=3306
DB_NAME="4755283_portfoliodb"
DB_USER="4755283_portfoliodb"
DB_PASSWORD="anik@2626#"

# ---------- Default admin (seeded on first boot) ----------
# IMPORTANT: change the password from the admin Account page after
# the first successful login. These values only seed the very first
# administrator row.
ADMIN_USER="admin"
ADMIN_PASS="admin1234"
ADMIN_EMAIL="admin@aniksen.local"
